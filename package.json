{
  "name": "pos-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:emulator": "NEXT_PUBLIC_APP_ENV=emulator next dev --webpack",
    "dev:turbo": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "emulators": "firebase emulators:start --project demo-warkocap --import=./firebase-data --export-on-exit=./firebase-data",
    "emulators:export": "firebase emulators:export ./firebase-data --force",
    "emulators:reset": "rm -rf ./firebase-data",
    "seed:emulator": "NEXT_PUBLIC_APP_ENV=emulator NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-warkocap npx tsx scripts/seed.ts",
    "test:checkout-bug": "NEXT_PUBLIC_APP_ENV=emulator NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-warkocap npx tsx scripts/test-checkout-bug.ts"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "dotenv": "^17.4.2",
    "file-saver": "^2.0.5",
    "firebase": "^12.14.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-modal": "^3.16.3",
    "sass": "^1.100.0",
    "sweetalert2": "^11.26.25",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-modal": "^3.16.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "firebase-tools": "^15.23.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  }
}
